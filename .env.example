# ── LLM Provider Keys ──
# 火山引擎 (默认)
VOLCENGINE_API_KEY=

# OpenAI (可选)
OPENAI_API_KEY=

# Anthropic (可选)
ANTHROPIC_API_KEY=

# ── 数据库 ──
# Docker Compose 会自动拼接 DATABASE_URL，以下变量用于自定义
POSTGRES_DB=lifeagent
POSTGRES_USER=lifeagent
POSTGRES_PASSWORD=lifeagent
REDIS_URL=redis://redis:6379/0

# ── Docker 部署 ──
NGINX_PORT=80

# ── 可选服务 ──
MEM0_API_KEY=
MEMOBASE_URL=
MILVUS_HOST=
